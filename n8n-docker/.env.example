# ============================================
# n8n Environment Variables (Production)
# ============================================

# HTTPS & Let's Encrypt
LETSENCRYPT_EMAIL=your-email@example.com

# n8n Configuration
N8N_VERSION=1.0.0
N8N_HOST=n8n.example.com
N8N_PORT=5678
N8N_PROTOCOL=https
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin

# Evolution API (WhatsApp)
EVOLUTION_HOST=api.example.com
EVOLUTION_API_KEY=your_secure_evolution_api_key

# PostgreSQL Database
POSTGRES_DB=n8n
POSTGRES_USER=n8n
# POSTGRES_PASSWORD should be in secrets/postgres_password file

# PostgreSQL Connection Pool
POSTGRES_MAX_CONNECTIONS=200

# n8n Security
NODE_ENV=production
TZ=America/Argentina/Buenos_Aires

# Logging
LOG_LEVEL=info

# Webhook Configuration
N8N_WEBHOOK_TUNNEL_URL=https://n8n.example.com/

# Email Configuration (Optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_AUTH_USER=your-email@example.com
# SMTP_AUTH_PASS should be in secrets/ file

# Backups
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"  # 2 AM daily

# Monitoring
SENTRY_DSN=

# Performance
N8N_ENABLE_METRICS=true
